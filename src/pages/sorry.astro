---
import Layout from '../layouts/Layout.astro';
---

<Layout title="I'm Sorry">
  <main class="sorry-wrap">
    <div id="drops" aria-hidden="true"></div>
    <div id="sparkles" aria-hidden="true"></div>
    <h1>I'm Sorry</h1>
    <div class="vignette" aria-hidden="true"></div>
  </main>
</Layout>

<style is:global>
  .sorry-wrap {
    min-height: 100svh;
    background: radial-gradient(circle at center, #000a18 0%, #0a0a0a 72%);
    display: grid;
    place-items: center;
    overflow: hidden;
    position: relative;
  }
  h1 {
    margin: 0;
    font-family: 'Dancing Script', cursive;
    font-size: clamp(3.5rem, 14vw, 10rem);
    color: #86b4ff;
    letter-spacing: 0.03em;
    text-shadow:
      0 0 8px rgba(134, 180, 255, 0.9),
      0 0 24px rgba(88, 150, 255, 0.75),
      0 0 48px rgba(65, 130, 255, 0.55),
      0 0 90px rgba(88, 150, 255, 0.35);
    animation: sorryPulse 3.2s infinite;
    z-index: 3;
  }
  @keyframes sorryPulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.04); opacity: 0.85; }
  }

  #drops,
  #sparkles {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .drop {
    position: absolute;
    width: var(--size);
    height: var(--height);
    top: -80px;
    background: var(--color);
    border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
    box-shadow: 0 0 14px var(--glow), 0 0 28px var(--glow);
    animation: fallDrop var(--dur) linear forwards;
    filter: blur(var(--blur));
    opacity: 0.65;
    touch-action: manipulation;
    pointer-events: auto;
  }

  .drop.popping {
    animation: popDrop 150ms ease-out forwards !important;
  }

  @keyframes fallDrop {
    0% {
      transform: translateX(0) translateY(0);
      opacity: 0;
    }
    10% { opacity: 0.7; }
    100% {
      transform: translateX(var(--sway)) translateY(120vh);
      opacity: 0;
    }
  }
  @keyframes popDrop {
    0% { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(1.5); opacity: 0; }
  }

  .fragment {
    position: absolute;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #7db6ff;
    box-shadow: 0 0 10px rgba(125, 182, 255, 0.9), 0 0 18px rgba(95, 167, 255, 0.6);
    pointer-events: none;
    z-index: 4;
  }

  .pop-flash {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.95);
    box-shadow: 0 0 18px rgba(255, 255, 255, 0.7);
    pointer-events: none;
    transform: translate(-50%, -50%);
    animation: popFlash 200ms ease-out forwards;
    z-index: 5;
  }
  @keyframes popFlash {
    0% { opacity: 0.95; transform: translate(-50%, -50%) scale(0.2); }
    100% { opacity: 0; transform: translate(-50%, -50%) scale(4.2); }
  }

  .sparkle {
    position: absolute;
    width: 2px;
    height: 2px;
    border-radius: 50%;
    background: #c0d8ff;
    box-shadow: 0 0 8px rgba(192, 216, 255, 0.9);
    animation: sparkle 2s ease-out forwards;
  }

  @keyframes sparkle {
    0% { transform: scale(0.2); opacity: 0; }
    30% { opacity: 1; }
    100% { transform: scale(1.2); opacity: 0; }
  }

  .vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle at center, transparent 55%, rgba(60, 100, 255, 0.08) 100%);
    z-index: 2;
  }
</style>

<script>
  const drops = document.getElementById('drops');
  const sparkles = document.getElementById('sparkles');
  const colors = ['#7db6ff', '#5fa7ff', '#8f9fff', '#8cbff8', '#a3c7ff'];
  const fragments: { el: HTMLElement; x: number; y: number; vx: number; vy: number; life: number; maxLife: number }[] = [];

  function spawnDrop() {
    if (!drops) return;
    const d = document.createElement('span');
    d.className = 'drop';
    const size = Math.random() * 10 + 6;
    const height = size * (1.8 + Math.random() * 0.8);
    const blur = Math.random() < 0.35 ? `${(Math.random() * 1.7 + 0.6).toFixed(2)}px` : '0px';
    const color = colors[Math.floor(Math.random() * colors.length)];
    d.style.setProperty('--size', `${size}px`);
    d.style.setProperty('--height', `${height}px`);
    d.style.setProperty('--blur', blur);
    d.style.setProperty('--color', color);
    d.style.setProperty('--glow', `${color}88`);
    d.style.setProperty('--sway', `${(Math.random() - 0.5) * 60}px`);
    d.style.setProperty('--dur', `${Math.random() * 3 + 4}s`);
    d.style.left = `${Math.random() * 100}%`;
    drops.appendChild(d);
    setTimeout(() => d.remove(), 8000);
  }

  function spawnSparkle() {
    if (!sparkles) return;
    const s = document.createElement('span');
    s.className = 'sparkle';
    const cx = 50 + (Math.random() - 0.5) * 18;
    const cy = 50 + (Math.random() - 0.5) * 18;
    s.style.left = `${cx}%`;
    s.style.top = `${cy}%`;
    s.style.animationDuration = `${Math.random() * 1.4 + 1.2}s`;
    sparkles.appendChild(s);
    setTimeout(() => s.remove(), 2400);
  }

  function spawnPopFlash(x: number, y: number) {
    if (!drops) return;
    const flash = document.createElement('span');
    flash.className = 'pop-flash';
    flash.style.left = `${x}px`;
    flash.style.top = `${y}px`;
    drops.appendChild(flash);
    setTimeout(() => flash.remove(), 220);
  }

  function spawnFragments(x: number, y: number, color: string) {
    if (!drops) return;
    const count = 6 + Math.floor(Math.random() * 3);
    for (let i = 0; i < count; i++) {
      const angle = (Math.PI * 2 * i) / count + (Math.random() - 0.5) * 0.45;
      const speed = 1.5 + Math.random() * 2.1;
      const el = document.createElement('span');
      el.className = 'fragment';
      el.style.left = `${x}px`;
      el.style.top = `${y}px`;
      el.style.background = color;
      el.style.boxShadow = `0 0 10px ${color}, 0 0 18px ${color}88`;
      drops.appendChild(el);
      fragments.push({ el, x, y, vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed - 1.4, life: 26 + Math.random() * 10, maxLife: 36 });
    }
  }

  function updateFragments() {
    for (let i = fragments.length - 1; i >= 0; i--) {
      const f = fragments[i];
      f.life -= 1;
      f.vy += 0.14;
      f.x += f.vx;
      f.y += f.vy;
      const alpha = Math.max(0, f.life / f.maxLife);
      f.el.style.transform = `translate(${f.x}px, ${f.y}px)`;
      f.el.style.opacity = alpha.toFixed(2);
      if (f.life <= 0) {
        f.el.remove();
        fragments.splice(i, 1);
      }
    }
    requestAnimationFrame(updateFragments);
  }

  drops?.addEventListener('pointerdown', (e) => {
    const drop = (e.target as HTMLElement).closest('.drop') as HTMLElement | null;
    if (!drop || drop.classList.contains('popping')) return;
    const rect = drop.getBoundingClientRect();
    const parentRect = drops!.getBoundingClientRect();
    const px = (e.clientX || rect.left + rect.width / 2) - parentRect.left;
    const py = (e.clientY || rect.top + rect.height / 2) - parentRect.top;
    const color = drop.style.getPropertyValue('--color') || '#7db6ff';

    drop.classList.add('popping');
    spawnPopFlash(px, py);
    spawnFragments(px, py, color);
    setTimeout(() => drop.remove(), 160);
  });

  for (let i = 0; i < 30; i++) setTimeout(spawnDrop, i * 120);
  setInterval(spawnDrop, 180);
  setInterval(spawnSparkle, 250);
  updateFragments();
</script>
