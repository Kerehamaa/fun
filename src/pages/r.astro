---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Rebecca">
  <main class="rebecca-wrap">
    <div id="hearts" aria-hidden="true"></div>
    <h1>Rebecca</h1>
  </main>
</Layout>

<style>
  .rebecca-wrap {
    min-height: 100svh;
    background: #0a0a0a;
    display: grid;
    place-items: center;
    overflow: hidden;
    position: relative;
  }
  h1 {
    margin: 0;
    font-size: clamp(3rem, 14vw, 9rem);
    color: #ff69b4;
    letter-spacing: 0.04em;
    text-shadow: 0 0 10px rgba(255, 20, 147, 0.5), 0 0 28px rgba(255, 20, 147, 0.65);
    animation: heartbeat 2.2s infinite;
    z-index: 2;
  }
  @keyframes heartbeat {
    0%, 32%, 100% { transform: scale(1); text-shadow: 0 0 10px rgba(255, 20, 147, 0.45), 0 0 26px rgba(255, 20, 147, 0.6); }
    8% { transform: scale(1.05); text-shadow: 0 0 16px rgba(255, 20, 147, 0.7), 0 0 44px rgba(255, 20, 147, 0.9); }
    16% { transform: scale(1.02); }
    24% { transform: scale(1.05); text-shadow: 0 0 16px rgba(255, 105, 180, 0.75), 0 0 42px rgba(255, 20, 147, 0.85); }
  }
  #hearts {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .heart {
    position: absolute;
    bottom: -2rem;
    color: rgba(255, 105, 180, 0.6);
    animation: floatUp linear forwards;
  }
  @keyframes floatUp {
    to { transform: translateY(-115vh) translateX(var(--drift)); opacity: 0; }
  }
</style>

<script>
  const hearts = document.getElementById('hearts');
  function spawnHeart() {
    if (!hearts) return;
    const h = document.createElement('span');
    h.className = 'heart';
    h.textContent = '♥';
    h.style.left = `${Math.random() * 100}%`;
    h.style.fontSize = `${Math.random() * 30 + 12}px`;
    h.style.setProperty('--drift', `${(Math.random() - 0.5) * 60}px`);
    h.style.animationDuration = `${Math.random() * 4 + 5}s`;
    hearts.appendChild(h);
    setTimeout(() => h.remove(), 9000);
  }
  for (let i = 0; i < 24; i++) setTimeout(spawnHeart, i * 190);
  setInterval(spawnHeart, 260);
</script>
