---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Rebecca">
  <main class="rebecca-wrap">
    <div id="hearts" aria-hidden="true"></div>
    <div id="sparkles" aria-hidden="true"></div>
    <h1>Rebecca</h1>
    <div class="vignette" aria-hidden="true"></div>
  </main>
</Layout>

<style is:global>
  .rebecca-wrap {
    min-height: 100svh;
    background: radial-gradient(circle at center, #120008 0%, #0a0a0a 72%);
    display: grid;
    place-items: center;
    overflow: hidden;
    position: relative;
  }
  h1 {
    margin: 0;
    font-family: 'Dancing Script', cursive;
    font-size: clamp(4rem, 16vw, 11rem);
    color: #ff86b4;
    letter-spacing: 0.03em;
    text-shadow:
      0 0 8px rgba(255, 136, 189, 0.9),
      0 0 24px rgba(255, 88, 160, 0.75),
      0 0 48px rgba(255, 65, 145, 0.55),
      0 0 90px rgba(255, 88, 160, 0.35);
    animation: heartPulse 2.35s infinite;
    z-index: 3;
  }
  @keyframes heartPulse {
    0%, 36%, 100% { transform: scale(1); }
    8% { transform: scale(1.08); }
    16% { transform: scale(1.02); }
    24% { transform: scale(1.09); }
    30% { transform: scale(1); }
  }

  #hearts,
  #sparkles {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .heart {
    position: absolute;
    width: var(--size);
    height: var(--size);
    bottom: -80px;
    background: var(--color);
    transform: rotate(45deg);
    border-radius: 24% 24% 8% 8%;
    box-shadow: 0 0 14px var(--glow), 0 0 28px var(--glow);
    animation: floatHeart var(--dur) linear forwards;
    filter: blur(var(--blur));
    opacity: 0.72;
    touch-action: manipulation;
    pointer-events: auto;
  }
  .heart::before,
  .heart::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: inherit;
  }
  .heart::before { left: -50%; top: 0; }
  .heart::after { left: 0; top: -50%; }

  .heart.popping {
    animation: popHeart 150ms ease-out forwards !important;
  }

  @keyframes floatHeart {
    0% {
      transform: translateX(0) translateY(0) rotate(45deg);
      opacity: 0;
    }
    10% { opacity: 0.75; }
    100% {
      transform: translateX(var(--sway)) translateY(-120vh) rotate(45deg);
      opacity: 0;
    }
  }
  @keyframes popHeart {
    0% { transform: scale(1) rotate(45deg); opacity: 0.8; }
    100% { transform: scale(1.5) rotate(45deg); opacity: 0; }
  }

  .fragment {
    position: absolute;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #ff7db6;
    box-shadow: 0 0 10px rgba(255, 125, 182, 0.9), 0 0 18px rgba(255, 95, 167, 0.6);
    pointer-events: none;
    z-index: 4;
  }

  .pop-flash {
    position: absolute;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.95);
    box-shadow: 0 0 18px rgba(255, 255, 255, 0.7);
    pointer-events: none;
    transform: translate(-50%, -50%);
    animation: popFlash 200ms ease-out forwards;
    z-index: 5;
  }
  @keyframes popFlash {
    0% { opacity: 0.95; transform: translate(-50%, -50%) scale(0.2); }
    100% { opacity: 0; transform: translate(-50%, -50%) scale(4.2); }
  }

  .sparkle {
    position: absolute;
    width: 2px;
    height: 2px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 8px rgba(255, 255, 255, 0.9);
    animation: sparkle 2s ease-out forwards;
  }

  @keyframes sparkle {
    0% { transform: scale(0.2); opacity: 0; }
    30% { opacity: 1; }
    100% { transform: scale(1.2); opacity: 0; }
  }

  .vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle at center, transparent 55%, rgba(255, 60, 140, 0.08) 100%);
    z-index: 2;
  }
</style>

<script>
  const hearts = document.getElementById('hearts');
  const sparkles = document.getElementById('sparkles');
  const colors = ['#ff7db6', '#ff5fa7', '#ff8f9f', '#f88cbf', '#ffa3c7'];
  const fragments = [];

  function spawnHeart() {
    if (!hearts) return;
    const h = document.createElement('span');
    h.className = 'heart';
    const size = Math.random() * 24 + 14;
    const blur = Math.random() < 0.35 ? `${(Math.random() * 1.7 + 0.6).toFixed(2)}px` : '0px';
    const color = colors[Math.floor(Math.random() * colors.length)];
    h.style.setProperty('--size', `${size}px`);
    h.style.setProperty('--blur', blur);
    h.style.setProperty('--color', color);
    h.style.setProperty('--glow', `${color}88`);
    h.style.setProperty('--sway', `${(Math.random() - 0.5) * 140}px`);
    h.style.setProperty('--dur', `${Math.random() * 4.8 + 7.5}s`);
    h.style.left = `${Math.random() * 100}%`;
    hearts.appendChild(h);
    setTimeout(() => h.remove(), 13000);
  }

  function spawnSparkle() {
    if (!sparkles) return;
    const s = document.createElement('span');
    s.className = 'sparkle';
    const cx = 50 + (Math.random() - 0.5) * 18;
    const cy = 50 + (Math.random() - 0.5) * 18;
    s.style.left = `${cx}%`;
    s.style.top = `${cy}%`;
    s.style.animationDuration = `${Math.random() * 1.4 + 1.2}s`;
    sparkles.appendChild(s);
    setTimeout(() => s.remove(), 2400);
  }

  function spawnPopFlash(x, y) {
    if (!hearts) return;
    const flash = document.createElement('span');
    flash.className = 'pop-flash';
    flash.style.left = `${x}px`;
    flash.style.top = `${y}px`;
    hearts.appendChild(flash);
    setTimeout(() => flash.remove(), 220);
  }

  function spawnFragments(x, y, color) {
    if (!hearts) return;
    const count = 6 + Math.floor(Math.random() * 3);
    for (let i = 0; i < count; i++) {
      const angle = (Math.PI * 2 * i) / count + (Math.random() - 0.5) * 0.45;
      const speed = 1.5 + Math.random() * 2.1;
      const el = document.createElement('span');
      el.className = 'fragment';
      el.style.left = `${x}px`;
      el.style.top = `${y}px`;
      el.style.background = color;
      el.style.boxShadow = `0 0 10px ${color}, 0 0 18px ${color}88`;
      hearts.appendChild(el);
      fragments.push({ el, x, y, vx: Math.cos(angle) * speed, vy: Math.sin(angle) * speed - 1.4, life: 26 + Math.random() * 10, maxLife: 36 });
    }
  }

  function updateFragments() {
    for (let i = fragments.length - 1; i >= 0; i--) {
      const f = fragments[i];
      f.life -= 1;
      f.vy += 0.14;
      f.x += f.vx;
      f.y += f.vy;
      const alpha = Math.max(0, f.life / f.maxLife);
      f.el.style.transform = `translate(${f.x}px, ${f.y}px)`;
      f.el.style.opacity = alpha.toFixed(2);
      if (f.life <= 0) {
        f.el.remove();
        fragments.splice(i, 1);
      }
    }
    requestAnimationFrame(updateFragments);
  }

  hearts?.addEventListener('pointerdown', (e) => {
    const heart = e.target.closest('.heart');
    if (!heart || heart.classList.contains('popping')) return;
    const rect = heart.getBoundingClientRect();
    const parentRect = hearts.getBoundingClientRect();
    const px = (e.clientX || rect.left + rect.width / 2) - parentRect.left;
    const py = (e.clientY || rect.top + rect.height / 2) - parentRect.top;
    const color = heart.style.getPropertyValue('--color') || '#ff7db6';

    heart.classList.add('popping');
    spawnPopFlash(px, py);
    spawnFragments(px, py, color);
    setTimeout(() => heart.remove(), 160);
  });

  for (let i = 0; i < 30; i++) setTimeout(spawnHeart, i * 180);
  setInterval(spawnHeart, 260);
  setInterval(spawnSparkle, 210);
  updateFragments();
</script>
