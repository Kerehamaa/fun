<section class="play-section gravity" id="gravity">
  <h2 class="section-title">gravity playground</h2>
  <canvas id="gravity-canvas" width="1200" height="600"></canvas>
  <div class="gravity-controls">
    <button id="shake-btn">shake</button>
    <button id="flip-btn">flip gravity</button>
  </div>
  <div id="dog-easter">teddy &amp; bear 🐾</div>
</section>

<style>
  .gravity {
    background: radial-gradient(circle at 50% 30%, rgba(168, 85, 247, 0.13), #0a0a0a 62%);
    color: #cfb4ff;
  }
  #gravity-canvas {
    width: min(1100px, 100%);
    border: 1px solid rgba(168, 85, 247, 0.4);
    border-radius: 1rem;
    background: linear-gradient(to bottom, rgba(139, 92, 246, 0.07), rgba(10, 10, 10, 0.35));
    touch-action: none;
  }
  .gravity-controls {
    margin-top: 1rem;
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .gravity-controls button {
    padding: 0.7rem 1.1rem;
    border-radius: 0.6rem;
    background: #8b5cf6;
    color: #fff;
    font-weight: 700;
  }
  #dog-easter {
    margin-top: 0.8rem;
    opacity: 0;
    transition: opacity 400ms ease;
    color: #f3ddff;
    text-shadow: 0 0 8px rgba(168, 85, 247, 0.6);
  }
  #dog-easter.show { opacity: 1; }
</style>

<script>
  const sectionG = document.getElementById('gravity');
  const canvas = document.getElementById('gravity-canvas');
  const ctx = canvas?.getContext('2d');
  const shakeBtn = document.getElementById('shake-btn');
  const flipBtn = document.getElementById('flip-btn');
  const easter = document.getElementById('dog-easter');
  const colors = ['#8b5cf6', '#a855f7', '#22d3ee', '#f472b6', '#facc15', '#34d399'];

  let shapes = [];
  let gravity = 0.26;
  let running = false;
  let dogDrop = false;
  let animId;
  let dragId = null;

  const resizeCanvas = () => {
    if (!canvas || !sectionG) return;
    const rect = sectionG.querySelector('#gravity-canvas').getBoundingClientRect();
    canvas.width = rect.width * Math.min(window.devicePixelRatio, 2);
    canvas.height = 600 * Math.min(window.devicePixelRatio, 2);
    if (ctx) ctx.scale(Math.min(window.devicePixelRatio, 2), Math.min(window.devicePixelRatio, 2));
  };

  function spawn(x = Math.random() * 900 + 80, y = Math.random() * 180 + 10) {
    const types = ['circle', 'square', 'triangle'];
    const type = types[Math.floor(Math.random() * types.length)];
    const r = Math.random() * 16 + 14;
    shapes.push({
      x, y, r,
      vx: (Math.random() - 0.5) * 2,
      vy: (Math.random() - 0.5) * 2,
      color: colors[Math.floor(Math.random() * colors.length)],
      type,
    });
    if (shapes.length >= 20 && !dogDrop) {
      dogDrop = true;
      easter?.classList.add('show');
      setTimeout(() => easter?.classList.remove('show'), 3000);
    }
  }

  function drawShape(s) {
    if (!ctx) return;
    ctx.fillStyle = s.color;
    ctx.beginPath();
    if (s.type === 'circle') ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
    if (s.type === 'square') ctx.rect(s.x - s.r, s.y - s.r, s.r * 2, s.r * 2);
    if (s.type === 'triangle') {
      ctx.moveTo(s.x, s.y - s.r);
      ctx.lineTo(s.x - s.r, s.y + s.r);
      ctx.lineTo(s.x + s.r, s.y + s.r);
      ctx.closePath();
    }
    ctx.fill();
  }

  function drawDogs() {
    if (!ctx || !dogDrop) return;
    const t = (performance.now() % 3500) / 3500;
    const y = t < 0.7 ? -80 + t * 520 : 290;
    ctx.font = '42px Space Grotesk';
    ctx.fillText('🐕', 220, y);
    ctx.fillText('🐕', 280, y + 6);
  }

  function update() {
    if (!running || !ctx || !canvas) return;
    const w = canvas.width / Math.min(window.devicePixelRatio, 2);
    const h = canvas.height / Math.min(window.devicePixelRatio, 2);
    ctx.clearRect(0, 0, w, h);

    for (let i = 0; i < shapes.length; i++) {
      const s = shapes[i];
      if (dragId !== i) {
        s.vy += gravity;
        s.x += s.vx;
        s.y += s.vy;
      }

      const floor = gravity > 0 ? h - s.r : s.r;
      if ((gravity > 0 && s.y > floor) || (gravity < 0 && s.y < floor)) {
        s.y = floor;
        s.vy *= -0.72;
        s.vx *= 0.98;
      }
      if (s.x < s.r || s.x > w - s.r) {
        s.vx *= -0.82;
        s.x = Math.max(s.r, Math.min(w - s.r, s.x));
      }

      for (let j = i + 1; j < shapes.length; j++) {
        const o = shapes[j];
        const dx = o.x - s.x;
        const dy = o.y - s.y;
        const dist = Math.hypot(dx, dy);
        const minD = s.r + o.r;
        if (dist < minD && dist > 0) {
          const nx = dx / dist;
          const ny = dy / dist;
          const overlap = (minD - dist) * 0.5;
          s.x -= nx * overlap;
          s.y -= ny * overlap;
          o.x += nx * overlap;
          o.y += ny * overlap;
          s.vx -= nx * 0.45; s.vy -= ny * 0.45;
          o.vx += nx * 0.45; o.vy += ny * 0.45;
        }
      }
      drawShape(s);
    }
    drawDogs();
    animId = requestAnimationFrame(update);
  }

  function pointerPos(e) {
    const rect = canvas.getBoundingClientRect();
    return { x: e.clientX - rect.left, y: e.clientY - rect.top };
  }

  if (canvas && sectionG) {
    for (let i = 0; i < 8; i++) spawn();
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    canvas.addEventListener('pointerdown', (e) => {
      const p = pointerPos(e);
      let hit = null;
      shapes.forEach((s, i) => {
        if (Math.hypot(p.x - s.x, p.y - s.y) < s.r) hit = i;
      });
      if (hit !== null) {
        dragId = hit;
      } else {
        spawn(p.x, p.y);
      }
    });
    canvas.addEventListener('pointermove', (e) => {
      if (dragId === null) return;
      const p = pointerPos(e);
      const s = shapes[dragId];
      s.x = p.x; s.y = p.y; s.vx = 0; s.vy = 0;
    });
    ['pointerup', 'pointerleave', 'pointercancel'].forEach((ev) =>
      canvas.addEventListener(ev, () => (dragId = null))
    );

    shakeBtn?.addEventListener('click', () => {
      shapes.forEach((s) => { s.vx += (Math.random() - 0.5) * 9; s.vy += (Math.random() - 0.5) * 9; });
    });
    flipBtn?.addEventListener('click', () => { gravity *= -1; });

    new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        running = entry.isIntersecting;
        if (running) update();
        else cancelAnimationFrame(animId);
      });
    }, { threshold: 0.2 }).observe(sectionG);
  }
</script>
