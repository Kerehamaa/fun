<section class="play-section text-exploder" id="exploder">
  <h2 class="section-title cracked">break things</h2>
  <p id="exploder-text"></p>
  <p id="secret-message">you broke everything. nice. 🧡</p>
</section>

<style>
  .text-exploder {
    background: radial-gradient(circle at center, rgba(255, 165, 0, 0.15), #0a0a0a 64%);
    color: #ffd39a;
    overflow: hidden;
  }
  .cracked {
    position: relative;
  }
  .cracked::after {
    content: '';
    position: absolute;
    left: 8%;
    right: 8%;
    top: 52%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 200, 120, 0.7) 20%, rgba(255, 120, 40, 0.85) 52%, rgba(255, 200, 120, 0.6) 85%, transparent);
    transform: rotate(-1.5deg);
    box-shadow: 0 0 8px rgba(255, 140, 0, 0.3);
  }
  #exploder-text {
    max-width: 900px;
    font-size: clamp(1.1rem, 2.2vw, 1.8rem);
    line-height: 1.8;
    text-align: center;
  }
  .word {
    display: inline-block;
    margin: 0 0.18em;
    padding: 0.05em 0.08em;
    border-radius: 0.2em;
    cursor: pointer;
    transition: color 180ms ease, background 180ms ease;
  }
  .word:hover {
    color: #ffb347;
    background: rgba(255, 140, 0, 0.16);
  }
  .word.broken {
    color: rgba(255, 205, 160, 0.58);
  }
  .letter-frag {
    position: fixed;
    pointer-events: none;
    font-weight: 700;
    text-shadow: 0 0 10px currentColor, 0 0 22px currentColor;
    filter: drop-shadow(0 0 8px currentColor);
    will-change: transform, opacity;
    z-index: 22;
  }
  .trail {
    position: fixed;
    pointer-events: none;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    opacity: 0.55;
    z-index: 21;
    animation: fadeTrail 320ms linear forwards;
  }
  #secret-message {
    margin-top: 1.5rem;
    font-size: clamp(1rem, 2vw, 1.4rem);
    color: #ffb86a;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 700ms ease, transform 700ms ease;
    text-shadow: 0 0 12px rgba(255, 160, 70, 0.5);
  }
  #secret-message.show {
    opacity: 1;
    transform: translateY(0);
  }
  @keyframes fadeTrail {
    to {
      transform: scale(0.1);
      opacity: 0;
    }
  }
</style>

<script>
  const text = `this sentence doesn't want to exist. hover over any word and it will shatter into pieces. try clicking too. nothing here is permanent. have fun breaking things.`;
  const holder = document.getElementById('exploder-text');
  const section = document.getElementById('exploder');
  const secret = document.getElementById('secret-message');
  const isTouchExploder = window.matchMedia('(pointer: coarse)').matches;
  const palette = ['#ff8a00', '#ffb703', '#ffd166', '#ff6d00', '#ffc857', '#ffa94d'];
  const explodedSet = new Set();

  if (holder) {
    holder.innerHTML = text
      .split(' ')
      .map((word, i) => `<span class="word" data-index="${i}">${word}</span>`)
      .join(' ');

    const words = [...holder.querySelectorAll('.word')];
    words.forEach((word) => {
      const explode = () => {
        explodeWord(word);
        word.classList.add('broken');
        explodedSet.add(word.dataset.index);
        if (explodedSet.size === words.length) secret?.classList.add('show');
      };
      if (!isTouchExploder) word.addEventListener('mouseenter', explode);
      word.addEventListener('click', explode);
    });
  }

  function shakeSection() {
    if (!section) return;
    section.animate(
      [
        { transform: 'translate(0, 0)' },
        { transform: `translate(${(Math.random() - 0.5) * 4}px, ${(Math.random() - 0.5) * 4}px)` },
        { transform: `translate(${(Math.random() - 0.5) * 4}px, ${(Math.random() - 0.5) * 4}px)` },
        { transform: 'translate(0, 0)' },
      ],
      { duration: 180, easing: 'ease-out' }
    );
  }

  function explodeWord(wordEl) {
    const rect = wordEl.getBoundingClientRect();
    const letters = wordEl.textContent.split('');
    const spanWidth = rect.width / Math.max(letters.length, 1);
    const fragments = [];

    shakeSection();

    letters.forEach((ch, i) => {
      const node = document.createElement('span');
      node.className = 'letter-frag';
      node.textContent = ch;
      const color = palette[Math.floor(Math.random() * palette.length)];
      node.style.color = color;
      const x = rect.left + i * spanWidth;
      const y = rect.top;
      node.style.left = `${x}px`;
      node.style.top = `${y}px`;
      document.body.appendChild(node);
      fragments.push({
        node,
        color,
        x,
        y,
        vx: (Math.random() - 0.5) * 7,
        vy: (Math.random() - 0.95) * 6,
        rot: Math.random() * 30,
        vr: (Math.random() - 0.5) * 22,
        opacity: 1,
      });
    });

    const gravity = 0.24;
    const start = performance.now();
    const duration = 2100;

    function tick() {
      const now = performance.now();
      const t = now - start;

      fragments.forEach((f) => {
        f.vy += gravity;
        f.x += f.vx;
        f.y += f.vy;
        f.rot += f.vr;
        f.opacity = Math.max(0, 1 - t / duration);

        const trail = document.createElement('span');
        trail.className = 'trail';
        trail.style.left = `${f.x}px`;
        trail.style.top = `${f.y}px`;
        trail.style.background = f.color;
        document.body.appendChild(trail);
        setTimeout(() => trail.remove(), 360);

        f.node.style.transform = `translate(${f.x - parseFloat(f.node.style.left)}px, ${f.y - parseFloat(f.node.style.top)}px) rotate(${f.rot}deg)`;
        f.node.style.opacity = f.opacity;
      });

      if (t < duration) {
        requestAnimationFrame(tick);
      } else {
        fragments.forEach((f) => f.node.remove());
      }
    }
    requestAnimationFrame(tick);
  }
</script>